<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cadastro de Usuário</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, Helvetica, sans-serif;
}

body{
    background:#2196F3;
    display:flex;
    justify-content:center;
    align-items:center;
    height:100vh;
}

.container{
    width:500px;
    background:#fff;
    padding:30px;
    border-radius:15px;
    box-shadow:0 0 15px rgba(0,0,0,0.3);
}

h1{
    text-align:center;
    color:#1565C0;
    margin-bottom:20px;
}

label{
    display:block;
    margin-top:10px;
    font-weight:bold;
}

input{
    width:100%;
    padding:10px;
    margin-top:5px;
    border:1px solid #999;
    border-radius:5px;
    font-size:16px;
}

button{
    width:100%;
    padding:12px;
    margin-top:20px;
    background:#1565C0;
    color:white;
    border:none;
    border-radius:5px;
    font-size:18px;
    cursor:pointer;
}

button:hover{
    background:#0D47A1;
}

#resultado{
    margin-top:20px;
    background:#f2f2f2;
    padding:15px;
    border-radius:10px;
    display:none;
}

#resultado h2{
    color:#1565C0;
    margin-bottom:10px;
}

p{
    margin:5px 0;
}
</style>

</head>

<body>

<div class="container">

<h1>Cadastro de Usuário</h1>

<label>Nome</label>
<input type="text" id="nome">

<label>Idade</label>
<input type="number" id="idade">

<label>Cidade</label>
<input type="text" id="cidade">

<label>Estado</label>
<input type="text" id="estado">

<label>Profissão</label>
<input type="text" id="profissao">

<label>E-mail</label>
<input type="email" id="email">

<button onclick="cadastrar()">Cadastrar</button>

<div id="resultado">
    <h2>Dados Cadastrados</h2>

    <p id="rNome"></p>
    <p id="rIdade"></p>
    <p id="rCidade"></p>
    <p id="rEstado"></p>
    <p id="rProfissao"></p>
    <p id="rEmail"></p>
</div>

</div>

<script>

function cadastrar(){

    let nome = document.getElementById("nome").value;
    let idade = document.getElementById("idade").value;
    let cidade = document.getElementById("cidade").value;
    let estado = document.getElementById("estado").value;
    let profissao = document.getElementById("profissao").value;
    let email = document.getElementById("email").value;

    document.getElementById("resultado").style.display="block";

    document.getElementById("rNome").innerHTML =
    "<b>Nome:</b> " + nome;

    document.getElementById("rIdade").innerHTML =
    "<b>Idade:</b> " + idade + " anos";

    document.getElementById("rCidade").innerHTML =
    "<b>Cidade:</b> " + cidade;

    document.getElementById("rEstado").innerHTML =
    "<b>Estado:</b> " + estado;

    document.getElementById("rProfissao").innerHTML =
    "<b>Profissão:</b> " + profissao;

    document.getElementById("rEmail").innerHTML =
    "<b>E-mail:</b> " + email;

}

</script>

</body>
</html>
